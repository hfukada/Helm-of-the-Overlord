{
  "name": "hoto",
  "version": "0.1.0",
  "description": "Multi-repo, multi-agent one-shot task manager",
  "type": "module",
  "bin": {
    "hoto": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "daemon": "bun run src/index.ts daemon start",
    "test": "bun test",
    "lint": "bunx biome lint ./src/",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "chromadb": "^1.9.2",
    "hono": "^4.7.0",
    "matrix-js-sdk": "^34.0.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
