{
  "name": "hoto",
  "version": "0.1.0",
  "description": "Multi-repo, multi-agent one-shot task manager",
  "type": "module",
  "bin": {
    "hoto": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "daemon": "bun run src/index.ts daemon start",
    "typecheck": "bunx tsc --noEmit",
    "build:web": "cd src/web && bun run build"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
