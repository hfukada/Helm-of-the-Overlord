# =============================================================================
# Hoto Configuration
# Copy to .env and adjust as needed: cp .env.example .env
# =============================================================================

# -- Daemon -------------------------------------------------------------------

# Workspace directory for DB, worktrees, task artifacts
# HOTO_WORKSPACE=~/.hoto-workspace

# Daemon listen address and port
# HOTO_HOST=127.0.0.1
# HOTO_PORT=7777

# Default Claude model for agent subprocesses
# HOTO_MODEL=claude-sonnet-4-6

# Log level: debug, info, warn, error
# HOTO_LOG_LEVEL=info

# -- ChromaDB (vector search) -------------------------------------------------

# ChromaDB server URL. If unreachable, falls back to keyword-only search.
# CHROMA_URL=http://127.0.0.1:8000

# -- Matrix Chat (optional, disabled by default) ------------------------------

# Set MATRIX_HOMESERVER_URL to enable the Matrix bot.
# MATRIX_HOMESERVER_URL=http://127.0.0.1:6167

# Bot identity -- auto-registers on first run if open registration is enabled
# MATRIX_BOT_USER=@hoto:localhost
# MATRIX_BOT_PASSWORD=hoto-bot-default

# Or supply a pre-existing access token instead of user/password
# MATRIX_BOT_TOKEN=

# -- Gitea (code review) ------------------------------------------------------

# Gitea server URL. If unset, Gitea integration is disabled.
# GITEA_URL=http://localhost:3000

# Admin API token -- needed once to auto-create the bot user.
# Create at: Gitea > Site Administration > Applications > Generate Token
# GITEA_ADMIN_TOKEN=

# Bot user credentials -- auto-registered on first run
# GITEA_BOT_USER=hoto-bot
# GITEA_BOT_PASSWORD=hoto-bot-default

# Gitea org to create repos under
# GITEA_ORG=hoto

# How often (ms) to poll PRs for review status
# GITEA_POLL_INTERVAL_MS=15000

# -- Legacy (optional, no longer required with ChromaDB) ----------------------

# Ollama host for embeddings -- only used if embeddings.ts is called directly
# OLLAMA_HOST=http://127.0.0.1:11434
# HOTO_EMBED_MODEL=nomic-embed-text
